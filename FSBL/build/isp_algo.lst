 557:../Drivers/ISP/isp/Src/isp_algo.c **** /**
 558:../Drivers/ISP/isp/Src/isp_algo.c ****   * @brief  ISP_Algo_ApplyCConv
 559:../Drivers/ISP/isp/Src/isp_algo.c ****   *         Apply Color Conversion matrix to RGB components, clamping output values to [0-255]
 560:../Drivers/ISP/isp/Src/isp_algo.c ****   * @param  hIsp:  ISP device handle.
 561:../Drivers/ISP/isp/Src/isp_algo.c ****   * @param  inR: Red component value
 562:../Drivers/ISP/isp/Src/isp_algo.c ****   * @param  inG: Green component value
 563:../Drivers/ISP/isp/Src/isp_algo.c ****   * @param  inB: Blue component value
 564:../Drivers/ISP/isp/Src/isp_algo.c ****   * @param  outR: pointer to Red component value after color conversion
 565:../Drivers/ISP/isp/Src/isp_algo.c ****   * @param  outG: pointer to Green component value after color conversion
 566:../Drivers/ISP/isp/Src/isp_algo.c ****   * @param  outB: pointer to Blue component value after color conversion
 567:../Drivers/ISP/isp/Src/isp_algo.c ****   * @retval None
 568:../Drivers/ISP/isp/Src/isp_algo.c ****   */
 569:../Drivers/ISP/isp/Src/isp_algo.c **** void ISP_Algo_ApplyCConv(ISP_HandleTypeDef *hIsp, uint32_t inR, uint32_t inG, uint32_t inB, uint32_
 570:../Drivers/ISP/isp/Src/isp_algo.c **** {
 571:../Drivers/ISP/isp/Src/isp_algo.c ****   ISP_ColorConvTypeDef colorConv;
 572:../Drivers/ISP/isp/Src/isp_algo.c ****   int64_t ccR, ccG, ccB;
 573:../Drivers/ISP/isp/Src/isp_algo.c **** 
 574:../Drivers/ISP/isp/Src/isp_algo.c ****   if ((ISP_SVC_ISP_GetColorConv(hIsp, &colorConv) == ISP_OK) && (colorConv.enable == 1))
 575:../Drivers/ISP/isp/Src/isp_algo.c ****   {
 576:../Drivers/ISP/isp/Src/isp_algo.c ****     /* Apply ColorConversion matrix to the input components */
 577:../Drivers/ISP/isp/Src/isp_algo.c ****     ccR = (int64_t) inR * colorConv.coeff[0][0] + (int64_t) inG * colorConv.coeff[0][1] + (int64_t)
 578:../Drivers/ISP/isp/Src/isp_algo.c ****     ccG = (int64_t) inR * colorConv.coeff[1][0] + (int64_t) inG * colorConv.coeff[1][1] + (int64_t)
 579:../Drivers/ISP/isp/Src/isp_algo.c ****     ccB = (int64_t) inR * colorConv.coeff[2][0] + (int64_t) inG * colorConv.coeff[2][1] + (int64_t)
 580:../Drivers/ISP/isp/Src/isp_algo.c **** 
 581:../Drivers/ISP/isp/Src/isp_algo.c ****     ccR /= ISP_CCM_PRECISION_FACTOR;
 582:../Drivers/ISP/isp/Src/isp_algo.c ****     ccG /= ISP_CCM_PRECISION_FACTOR;
 583:../Drivers/ISP/isp/Src/isp_algo.c ****     ccB /= ISP_CCM_PRECISION_FACTOR;
 584:../Drivers/ISP/isp/Src/isp_algo.c **** 
 585:../Drivers/ISP/isp/Src/isp_algo.c ****     /* Clamp values to 0-255 */
 586:../Drivers/ISP/isp/Src/isp_algo.c ****     ccR = (ccR < 0) ? 0 : (ccR > 255) ? 255 : ccR;
 587:../Drivers/ISP/isp/Src/isp_algo.c ****     ccG = (ccG < 0) ? 0 : (ccG > 255) ? 255 : ccG;
 588:../Drivers/ISP/isp/Src/isp_algo.c ****     ccB = (ccB < 0) ? 0 : (ccB > 255) ? 255 : ccB;
 589:../Drivers/ISP/isp/Src/isp_algo.c **** 
 590:../Drivers/ISP/isp/Src/isp_algo.c ****     *outR = (uint32_t) ccR;
 591:../Drivers/ISP/isp/Src/isp_algo.c ****     *outG = (uint32_t) ccG;
 592:../Drivers/ISP/isp/Src/isp_algo.c ****     *outB = (uint32_t) ccB;
 593:../Drivers/ISP/isp/Src/isp_algo.c ****   }
 594:../Drivers/ISP/isp/Src/isp_algo.c ****   else
 595:../Drivers/ISP/isp/Src/isp_algo.c ****   {
 596:../Drivers/ISP/isp/Src/isp_algo.c ****     *outR = inR;
 597:../Drivers/ISP/isp/Src/isp_algo.c ****     *outG = inG;
 598:../Drivers/ISP/isp/Src/isp_algo.c ****     *outB = inB;
 599:../Drivers/ISP/isp/Src/isp_algo.c ****   }
 600:../Drivers/ISP/isp/Src/isp_algo.c **** }
 601:../Drivers/ISP/isp/Src/isp_algo.c **** 
