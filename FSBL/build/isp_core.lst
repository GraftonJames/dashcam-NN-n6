 122:../Drivers/ISP/isp/Src/isp_core.c ****   /* Compute the ISP decimation value according to the sensor resolution and the maximum ISP resolu
 123:../Drivers/ISP/isp/Src/isp_core.c ****   /* It is mandatory to ensure that RAW frame size does not exceed 2688 width prior to demosaicing 
 124:../Drivers/ISP/isp/Src/isp_core.c ****   ISP_DecimationTypeDef decimation;
 125:../Drivers/ISP/isp/Src/isp_core.c ****   if ((hIsp->sensorInfo.width / ISP_DECIM_FACTOR_1) < ISP_RAW_MAX_WIDTH)
 126:../Drivers/ISP/isp/Src/isp_core.c ****   {
 127:../Drivers/ISP/isp/Src/isp_core.c ****     decimation.factor = ISP_DECIM_FACTOR_1;
 128:../Drivers/ISP/isp/Src/isp_core.c ****   }
 129:../Drivers/ISP/isp/Src/isp_core.c ****   else if ((hIsp->sensorInfo.width / ISP_DECIM_FACTOR_2) < ISP_RAW_MAX_WIDTH)
 130:../Drivers/ISP/isp/Src/isp_core.c ****   {
 131:../Drivers/ISP/isp/Src/isp_core.c ****     decimation.factor = ISP_DECIM_FACTOR_2;
 132:../Drivers/ISP/isp/Src/isp_core.c ****   }
 133:../Drivers/ISP/isp/Src/isp_core.c ****   else if ((hIsp->sensorInfo.width / ISP_DECIM_FACTOR_4) < ISP_RAW_MAX_WIDTH)
 134:../Drivers/ISP/isp/Src/isp_core.c ****   {
 135:../Drivers/ISP/isp/Src/isp_core.c ****     decimation.factor = ISP_DECIM_FACTOR_4;
 136:../Drivers/ISP/isp/Src/isp_core.c ****   }
 137:../Drivers/ISP/isp/Src/isp_core.c ****   else if ((hIsp->sensorInfo.width / ISP_DECIM_FACTOR_8) < ISP_RAW_MAX_WIDTH)
 138:../Drivers/ISP/isp/Src/isp_core.c ****   {
 139:../Drivers/ISP/isp/Src/isp_core.c ****     decimation.factor = ISP_DECIM_FACTOR_8;
ARM GAS  /tmp/cce5bGNG.s 			page 4


 140:../Drivers/ISP/isp/Src/isp_core.c ****   }
 141:../Drivers/ISP/isp/Src/isp_core.c ****   else
 142:../Drivers/ISP/isp/Src/isp_core.c ****   {
 143:../Drivers/ISP/isp/Src/isp_core.c ****     printf("ERROR: No possible decimation factor to target ISP RAW width constraint\r\n");
 144:../Drivers/ISP/isp/Src/isp_core.c ****     return ISP_ERR_DECIMATION_EINVAL;
 145:../Drivers/ISP/isp/Src/isp_core.c ****   }
 146:../Drivers/ISP/isp/Src/isp_core.c ****   ret = ISP_SVC_ISP_SetDecimation(hIsp, &decimation);
 147:../Drivers/ISP/isp/Src/isp_core.c ****   if (ret != ISP_OK)
 148:../Drivers/ISP/isp/Src/isp_core.c ****   {
 149:../Drivers/ISP/isp/Src/isp_core.c ****     return ret;
 150:../Drivers/ISP/isp/Src/isp_core.c ****   }
