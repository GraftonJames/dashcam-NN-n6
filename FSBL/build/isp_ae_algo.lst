  75:../Drivers/ISP/isp/Src/isp_ae_algo.c **** /**
  76:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   * @brief  isp_ae_compute_antiflcker
  77:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   *         ONLY USEFUL WHEN WHEN ANTI-FLICKER IS ACTIVATED
  78:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   *         Otherwise exposure time and gain are unchanged
  79:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   *         This function will compute an exposure time that eliminates the flickering effect
  80:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   *         and compensates with gain to still achieve the desired brightness
  81:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   * @param  gain             : current sensor gain value (mdB)
  82:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   * @param  exposure         : current sensor exposure time value (us)
ARM GAS  /tmp/ccVycH7I.s 			page 3


  83:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   * @param  adjusted_gain    : pointer to the new sensor gain value (mdB)
  84:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   * @param  adjusted_exposure: pointer to the new exposure time value (us)
  85:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   * @retval None
  86:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   */
  87:../Drivers/ISP/isp/Src/isp_ae_algo.c **** static void isp_ae_compute_antiflcker(uint32_t gain, uint32_t exposure,
  88:../Drivers/ISP/isp/Src/isp_ae_algo.c ****                                       uint32_t *adjusted_gain, uint32_t *adjusted_exposure)
  89:../Drivers/ISP/isp/Src/isp_ae_algo.c **** {
  90:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   /* Get equivalent gain/exposure where exposure is a multiple of the flickering period */
  91:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   float compensation_gain;
  92:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   uint32_t compensation_gain_mdb, compat_period_us;
  93:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   uint32_t up_equiv_exposure;
  94:../Drivers/ISP/isp/Src/isp_ae_algo.c **** 
  95:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   if (IQParamConfig->AECAlgo.antiFlickerFreq == 0)
  96:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   {
  97:../Drivers/ISP/isp/Src/isp_ae_algo.c ****     *adjusted_gain = gain;
  98:../Drivers/ISP/isp/Src/isp_ae_algo.c ****     *adjusted_exposure = exposure;
  99:../Drivers/ISP/isp/Src/isp_ae_algo.c ****     return;
 100:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   }
 101:../Drivers/ISP/isp/Src/isp_ae_algo.c **** 
 102:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   compat_period_us = 1000U * 1000U / (2U * IQParamConfig->AECAlgo.antiFlickerFreq);
 103:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   up_equiv_exposure = (1 + exposure / compat_period_us) * compat_period_us;
 104:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   if ((exposure > compat_period_us) && (exposure < 0.95 * up_equiv_exposure))
 105:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   {
 106:../Drivers/ISP/isp/Src/isp_ae_algo.c ****     /* Make exposure a multiple of the flickering period in case exposure is higher than the
 107:../Drivers/ISP/isp/Src/isp_ae_algo.c ****        flickering period and we are 5% under a multiple value */
 108:../Drivers/ISP/isp/Src/isp_ae_algo.c ****     *adjusted_exposure = (exposure / compat_period_us) * compat_period_us;
 109:../Drivers/ISP/isp/Src/isp_ae_algo.c **** 
 110:../Drivers/ISP/isp/Src/isp_ae_algo.c ****     /* Increase the gain accordingly */
 111:../Drivers/ISP/isp/Src/isp_ae_algo.c ****     compensation_gain = (float)exposure / (float)(*adjusted_exposure + 1);
 112:../Drivers/ISP/isp/Src/isp_ae_algo.c ****     compensation_gain_mdb = (uint32_t)(20 * 1000 * log10(compensation_gain));
 113:../Drivers/ISP/isp/Src/isp_ae_algo.c ****     *adjusted_gain = gain + compensation_gain_mdb;
 114:../Drivers/ISP/isp/Src/isp_ae_algo.c ****     if (*adjusted_gain > pSensorInfo->gain_max)
 115:../Drivers/ISP/isp/Src/isp_ae_algo.c ****     {
 116:../Drivers/ISP/isp/Src/isp_ae_algo.c ****       *adjusted_gain = pSensorInfo->gain_max;
 117:../Drivers/ISP/isp/Src/isp_ae_algo.c ****     }
 118:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   }
 119:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   else
 120:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   {
 121:../Drivers/ISP/isp/Src/isp_ae_algo.c ****     /* Keep the initial values in case:
 122:../Drivers/ISP/isp/Src/isp_ae_algo.c ****        - We cannot update the exposure because the values are under the flickering period (will fli
 123:../Drivers/ISP/isp/Src/isp_ae_algo.c ****        - Or we are close to the upper multiple value (the acceptance criteria is set to 95% of the
 124:../Drivers/ISP/isp/Src/isp_ae_algo.c ****          multiple value to ensure no flickering effect will be visible) */
 125:../Drivers/ISP/isp/Src/isp_ae_algo.c ****     *adjusted_gain = gain;
 126:../Drivers/ISP/isp/Src/isp_ae_algo.c ****     *adjusted_exposure = exposure;
 127:../Drivers/ISP/isp/Src/isp_ae_algo.c ****   }
 128:../Drivers/ISP/isp/Src/isp_ae_algo.c **** }
 129:../Drivers/ISP/isp/Src/isp_ae_algo.c **** 
