 283:Src/system_stm32n6xx_fsbl.c **** /**
 284:Src/system_stm32n6xx_fsbl.c ****   * @brief  Update SystemCoreClock variable according to Clock Register Values.
 285:Src/system_stm32n6xx_fsbl.c ****   *         The SystemCoreClock variable contains the core clock (HCLK), it can
 286:Src/system_stm32n6xx_fsbl.c ****   *         be used by the user application to setup the SysTick timer or configure
 287:Src/system_stm32n6xx_fsbl.c ****   *         other parameters.
 288:Src/system_stm32n6xx_fsbl.c ****   *
 289:Src/system_stm32n6xx_fsbl.c ****   * @note   Each time the CPU core clock changes, this function must be called
 290:Src/system_stm32n6xx_fsbl.c ****   *         to update SystemCoreClock variable value. Otherwise, any configuration
 291:Src/system_stm32n6xx_fsbl.c ****   *         based on this variable will be incorrect.
 292:Src/system_stm32n6xx_fsbl.c ****   *
 293:Src/system_stm32n6xx_fsbl.c ****   * @note   - The system frequency computed by this function is not the real
 294:Src/system_stm32n6xx_fsbl.c ****   *           frequency in the chip. It is calculated based on the predefined
ARM GAS  /tmp/ccDjXCr4.s 			page 11


 295:Src/system_stm32n6xx_fsbl.c ****   *           constant and the selected clock source:
 296:Src/system_stm32n6xx_fsbl.c ****   *
 297:Src/system_stm32n6xx_fsbl.c ****   *           - If CPUCLK source is HSI, SystemCoreClock will contain the HSI_VALUE(*)
 298:Src/system_stm32n6xx_fsbl.c ****   *
 299:Src/system_stm32n6xx_fsbl.c ****   *           - If CPUCLK source is MSI, SystemCoreClock will contain the MSI_VALUE(**)
 300:Src/system_stm32n6xx_fsbl.c ****   *
 301:Src/system_stm32n6xx_fsbl.c ****   *           - If CPUCLK source is HSE, SystemCoreClock will contain the HSE_VALUE(***)
 302:Src/system_stm32n6xx_fsbl.c ****   *
 303:Src/system_stm32n6xx_fsbl.c ****   *           - If CPUCLK source is IC1, SystemCoreClock will contain the HSI_VALUE(*)
 304:Src/system_stm32n6xx_fsbl.c ****   *             or MSI_VALUE(**) or HSE_VALUE(***) or EXTERNAL_I2S_CLOCK_VALUE (****)
 305:Src/system_stm32n6xx_fsbl.c ****   *             multiplied/divided by the PLL factors.
 306:Src/system_stm32n6xx_fsbl.c ****   *
 307:Src/system_stm32n6xx_fsbl.c ****   *         (*) HSI_VALUE default value is 64 MHz.
 308:Src/system_stm32n6xx_fsbl.c ****   *             With the HAL, HSI_VALUE is a constant defined in stm32n6xx_hal_conf.h file
 309:Src/system_stm32n6xx_fsbl.c ****   *             but the real value may vary depending on the variations in voltage and temperature.
 310:Src/system_stm32n6xx_fsbl.c ****   *
 311:Src/system_stm32n6xx_fsbl.c ****   *        (**) MSI_VALUE default value is 4 MHz.
 312:Src/system_stm32n6xx_fsbl.c ****   *             With the HAL, MSI_VALUE is a constant defined in stm32n6xx_hal_conf.h file
 313:Src/system_stm32n6xx_fsbl.c ****   *             but the real value may vary depending on the variations in voltage and temperature.
 314:Src/system_stm32n6xx_fsbl.c ****   *
 315:Src/system_stm32n6xx_fsbl.c ****   *       (***) HSE_VALUE default value is 30 MHz.
 316:Src/system_stm32n6xx_fsbl.c ****   *             With the HAL, HSE_VALUE is a constant defined in stm32n6xx_hal_conf.h file.
 317:Src/system_stm32n6xx_fsbl.c ****   *             User has to ensure that HSE_VALUE is same as the real frequency of the crystal used
 318:Src/system_stm32n6xx_fsbl.c ****   *             Otherwise, this function may have wrong result.
 319:Src/system_stm32n6xx_fsbl.c ****   *
 320:Src/system_stm32n6xx_fsbl.c ****   *      (****) EXTERNAL_I2S_CLOCK_VALUE default value is 12.288 MHz.
 321:Src/system_stm32n6xx_fsbl.c ****   *             With the HAL, EXTERNAL_I2S_CLOCK_VALUE is a constant defined in stm32n6xx_hal_conf.
 322:Src/system_stm32n6xx_fsbl.c ****   *             User has to ensure that EXTERNAL_I2S_CLOCK_VALUE is same as the real I2S_CKIN
 323:Src/system_stm32n6xx_fsbl.c ****   *             pin frequency. Otherwise, this function may have wrong result.
 324:Src/system_stm32n6xx_fsbl.c ****   *
 325:Src/system_stm32n6xx_fsbl.c ****   *         - The result of this function could be not correct when using fractional
 326:Src/system_stm32n6xx_fsbl.c ****   *           value for HSE crystal.
 327:Src/system_stm32n6xx_fsbl.c ****   *
 328:Src/system_stm32n6xx_fsbl.c ****   * @retval None
 329:Src/system_stm32n6xx_fsbl.c ****   */
 330:Src/system_stm32n6xx_fsbl.c **** void SystemCoreClockUpdate(void)
 331:Src/system_stm32n6xx_fsbl.c **** {
