 134:Src/system_stm32n6xx_fsbl.c ****   /* The SystemCoreClock variable is updated in three ways:
 135:Src/system_stm32n6xx_fsbl.c ****       1) by calling CMSIS function SystemCoreClockUpdate()
 136:Src/system_stm32n6xx_fsbl.c ****       2) by calling HAL API function HAL_RCC_GetHCLKFreq()
 137:Src/system_stm32n6xx_fsbl.c ****       3) each time HAL_RCC_ClockConfig() is called to configure the system clock frequency
 138:Src/system_stm32n6xx_fsbl.c ****          Note: If you use this function to configure the system clock; then there
 139:Src/system_stm32n6xx_fsbl.c ****                is no need to call the 2 first functions listed above, since SystemCoreClock
ARM GAS  /tmp/ccDjXCr4.s 			page 4


 140:Src/system_stm32n6xx_fsbl.c ****                variable is updated automatically.
 141:Src/system_stm32n6xx_fsbl.c ****   */
 142:Src/system_stm32n6xx_fsbl.c **** uint32_t SystemCoreClock = HSI_VALUE;
 143:Src/system_stm32n6xx_fsbl.c **** /**
