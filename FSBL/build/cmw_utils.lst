 168:../Drivers/cmw_camera/cmw_utils.c **** static void CMW_UTILS_get_crop_config(uint32_t cam_width, uint32_t cam_height, uint32_t pipe_width,
 169:../Drivers/cmw_camera/cmw_utils.c **** {
 170:../Drivers/cmw_camera/cmw_utils.c ****   const float ratio_width = (float)cam_width / pipe_width ;
 171:../Drivers/cmw_camera/cmw_utils.c ****   const float ratio_height = (float)cam_height / pipe_height;
 172:../Drivers/cmw_camera/cmw_utils.c ****   const float ratio = MIN(ratio_width, ratio_height);
 173:../Drivers/cmw_camera/cmw_utils.c **** 
 174:../Drivers/cmw_camera/cmw_utils.c ****   assert(ratio >= 1);
 175:../Drivers/cmw_camera/cmw_utils.c ****   assert(ratio < 64);
 176:../Drivers/cmw_camera/cmw_utils.c **** 
 177:../Drivers/cmw_camera/cmw_utils.c ****   crop->HSize = (uint32_t) MIN(pipe_width * ratio, cam_width);
 178:../Drivers/cmw_camera/cmw_utils.c ****   crop->VSize = (uint32_t) MIN(pipe_height * ratio, cam_height);
 179:../Drivers/cmw_camera/cmw_utils.c ****   crop->HStart = (cam_width - crop->HSize + 1) / 2;
 180:../Drivers/cmw_camera/cmw_utils.c ****   crop->VStart = (cam_height - crop->VSize + 1) / 2;
 181:../Drivers/cmw_camera/cmw_utils.c ****   crop->PipeArea = DCMIPP_POSITIVE_AREA;
 182:../Drivers/cmw_camera/cmw_utils.c **** }
