 109:../Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_rif.c ****     [..]
 110:../Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_rif.c ****     (#) Set or get a base region configuration with HAL_RIF_RISAF_ConfigBaseRegion /
 111:../Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_rif.c ****         HAL_RIF_RISAF_GetConfigBaseRegion.
 112:../Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_rif.c ****     (#) Set or get a subregion configuration with HAL_RIF_RISAF_ConfigSubRegion /
 113:../Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_rif.c ****         HAL_RIF_RISAF_GetConfigSubRegion.
 114:../Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_rif.c ****     (#) Delegate a subregion configuration to another CID with HAL_RIF_RISAF_ConfigSubRegionDelegat
 115:../Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_rif.c ****     (#) Get the data from an illegal access to a protected memory region with
 116:../Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_rif.c ****         HAL_RIF_RISAF_GetIllegalAccess.
 117:../Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_rif.c **** 
 118:../Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_rif.c ****      *** IAC related functions ***
 119:../Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_rif.c ****     ============================================================
