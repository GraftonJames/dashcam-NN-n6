 196:../Drivers/stm32n6xx_nucleo.c **** {
ARM GAS  /tmp/ccgkZaLJ.s 			page 5


 197:../Drivers/stm32n6xx_nucleo.c ****   int32_t ret = BSP_ERROR_NONE;
 198:../Drivers/stm32n6xx_nucleo.c ****   GPIO_InitTypeDef GPIO_Init;
 199:../Drivers/stm32n6xx_nucleo.c **** 
 200:../Drivers/stm32n6xx_nucleo.c ****   /* Enable the GPIO_LED Clock */
 201:../Drivers/stm32n6xx_nucleo.c ****   if (Led == LED1)
 202:../Drivers/stm32n6xx_nucleo.c ****   {
 203:../Drivers/stm32n6xx_nucleo.c ****     LED1_GPIO_CLK_ENABLE();
 204:../Drivers/stm32n6xx_nucleo.c ****   }
 205:../Drivers/stm32n6xx_nucleo.c ****   else if (Led == LED2)
 206:../Drivers/stm32n6xx_nucleo.c ****   {
 207:../Drivers/stm32n6xx_nucleo.c ****     LED2_GPIO_CLK_ENABLE();
 208:../Drivers/stm32n6xx_nucleo.c ****   }
 209:../Drivers/stm32n6xx_nucleo.c ****   else /* Led = LED3 */
 210:../Drivers/stm32n6xx_nucleo.c ****   {
 211:../Drivers/stm32n6xx_nucleo.c ****     LED3_GPIO_CLK_ENABLE();
 212:../Drivers/stm32n6xx_nucleo.c ****   }
 213:../Drivers/stm32n6xx_nucleo.c **** 
 214:../Drivers/stm32n6xx_nucleo.c ****   /* configure the GPIO_LED pin */
 215:../Drivers/stm32n6xx_nucleo.c ****   GPIO_Init.Pin   = LED_PIN[Led];
 216:../Drivers/stm32n6xx_nucleo.c ****   GPIO_Init.Mode  = GPIO_MODE_OUTPUT_PP;
 217:../Drivers/stm32n6xx_nucleo.c ****   GPIO_Init.Pull  = GPIO_NOPULL;
 218:../Drivers/stm32n6xx_nucleo.c ****   GPIO_Init.Speed = GPIO_SPEED_FREQ_VERY_HIGH;
 219:../Drivers/stm32n6xx_nucleo.c ****   HAL_GPIO_Init(LED_PORT[Led], &GPIO_Init);
 220:../Drivers/stm32n6xx_nucleo.c **** 
 221:../Drivers/stm32n6xx_nucleo.c ****   /* By default, turn off LED */
 222:../Drivers/stm32n6xx_nucleo.c ****   BSP_LED_Off(Led);
 223:../Drivers/stm32n6xx_nucleo.c ****   return ret;
 224:../Drivers/stm32n6xx_nucleo.c **** }
